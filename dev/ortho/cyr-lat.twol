Sets 

Vow = и ү е э ө а о у ы 
      И Ү Е Э Ө А О У Ы ;

!letter = ء ئ ا ە ب پ ت ج چ خ د ر ز ژ س ش غ ف ق ك گ ڭ ل م ن ھ و ۇ ۅ ۉ ۋ ى ي ;

backVow = а о ы у
          А О Ы У ;

frontVow = и ү е э ө
           И Ү Е Э Ө ;

Cons = б в г д ж з й к л м н п р с т ф х ц ч ш щ 
       Б В Г Д Ж З Й К Л М Н П Р С Т Ф Х Ц Ч Ш Щ ;

frontConsCyr = к г
               К Г ;

Nasal = Н М Ң
        н м ң ;

frontSound = k g e i ö ü
             K G E İ Ö Ü ;

backSound = q ğ a ı o u
            Q Ğ A I O U ;

Rules 

"%{й%}:y after vowels except е and after ъ"
%{й%}:y <=> [ Vow: - [ э: | е: ]/:0* ] _ ;
            ъ: _ ;

"к г in the context of back vowels"
Cx:Cy <=> :backSound _ [ .#. | \[ %{й%}: :frontSound ] | \:frontSound ] ;
          [ .#. | \:frontSound ] _ :backSound ;
      except
          .#. а: _ (%{й%}:) е: ;  ! аке:ake (*aqe)
          .#. б: (%{й%}:) е: _ а: ;  ! Бегайым:Begayım (*Beğayım)
          .#. _ Cons: ;    ! климат
          _ Cons: .#. ;    ! объект
          _ Cons: Cons: ;  ! объектке
          .#. б: л: о: _ ; ! блокада
          ! keep in mind if modifying this rule:
          ! - байке:bɑjke
          ! - багелек:bɑʁelek
      where Cx in ( к г К Г )
            Cy in ( q ğ Q Ğ )
      matched ;

"к and г in onset clusters (loanwords) and front-vowel contexts"
Cx:Cy <=> .#. _ Cons: ;    ! климат
          _ (%{й%}:) :frontSound ;
          :frontSound _ ;
          _ Cons: .#. ;    ! объект
          _ Cons: Cons: ;  ! объектке
          :frontSound Cons:+ _ ; ! Вашингтон
          .#. б: л: о: _ ; ! блокада
      where Cx in ( к г К Г )
            Cy in ( k g K G )
      matched ;

"ж as ʒ only after д"
ж:ž <=> [ д: | Д: ]  _ ;

"ъ:y before е"   ! объект:obyekt  (ю, я, ё should already get y)
ъ:y <=> _ [ е: | Е: ] ;


